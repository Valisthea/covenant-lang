{
  "version": 2,
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "examples.covenant-lang.org" }],
      "destination": "/examples/index"
    },
    {
      "source": "/:path+",
      "has": [{ "type": "host", "value": "examples.covenant-lang.org" }],
      "destination": "/examples/:path"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "docs.covenant-lang.org" }],
      "destination": "/docs/index.html"
    },
    {
      "source": "/:path+",
      "has": [{ "type": "host", "value": "docs.covenant-lang.org" }],
      "destination": "/docs/:path"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",         "value": "DENY" },
        { "key": "X-XSS-Protection",        "value": "1; mode=block" },
        { "key": "Referrer-Policy",         "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",      "value": "geolocation=(), microphone=(), camera=()" },
        { "key": "Strict-Transport-Security","value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/favicon.(svg|ico|png)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/og-image.(svg|png|jpg)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/apple-touch-icon.png",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/docs/_astro/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/docs/pagefind/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }]
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
